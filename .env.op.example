# 1Password secret references for agent-coherence live-API runs.
#
# These are NOT secrets. `op://...` is a *reference*; the 1Password CLI resolves
# it to the real value at runtime and injects it into the target process only —
# never to disk, shell history, or any agent's context. This file is safe to
# commit; the working copy `.env.op` is git-ignored so per-user vault/item names
# don't leak.
#
# Setup:
#   1. Install the CLI:   brew install 1password-cli
#   2. 1Password app -> Settings -> Developer -> enable "Integrate with 1Password CLI"
#   3. cp .env.op.example .env.op   then edit each op:// reference to match your items
#      (discover names with:  op item list   /   op item get "OpenAI")
#
# Run anything with these injected:
#   op run --env-file=.env.op -- <command>
# Or use the probe wrapper:
#   scripts/run-q6-probe.sh --vendor both --trials 100
#
# Reference format:  ENV_VAR=op://<vault>/<item>/<field>

OPENAI_API_KEY=op://Private/OpenAI/credential
MISTRAL_API_KEY=op://Private/Mistral/credential
