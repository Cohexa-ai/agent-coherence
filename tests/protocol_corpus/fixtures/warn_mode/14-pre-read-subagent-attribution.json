{
  "name": "pre-read-subagent-attribution",
  "description": "SB-25 R2 attribution: a subagent's commit is credited to the SUBAGENT id, not the parent session. Preflight: the parent reads (SHARED), then subagent A edits + commits v2 under the composite identity — invalidating the parent. The parent's re-read is stale and summary.last_writer_session_id MUST be the subagent id (the [:8] short form in prose then names the actual writer). Timestamps + prose are ignored (vary per run); the attribution field is the parity contract.",
  "setup": {
    "tracked": ["CLAUDE.md"],
    "files": {
      "CLAUDE.md": "# Project rules\n"
    },
    "preflight_requests": [
      {
        "method": "POST",
        "path": "/hooks/pre-read",
        "body": {
          "session_id": "44444444-4444-4444-8444-444444444444",
          "path": "CLAUDE.md"
        }
      },
      {
        "method": "POST",
        "path": "/hooks/pre-edit",
        "body": {
          "session_id": "44444444-4444-4444-8444-444444444444",
          "agent_id": "a0826622451ec196f",
          "path": "CLAUDE.md"
        }
      },
      {
        "method": "POST",
        "path": "/hooks/post-edit",
        "body": {
          "session_id": "44444444-4444-4444-8444-444444444444",
          "agent_id": "a0826622451ec196f",
          "path": "CLAUDE.md",
          "success": true,
          "content_hash": "2222222222222222222222222222222222222222222222222222222222222222"
        }
      }
    ]
  },
  "request": {
    "method": "POST",
    "path": "/hooks/pre-read",
    "body": {
      "session_id": "44444444-4444-4444-8444-444444444444",
      "path": "CLAUDE.md"
    }
  },
  "expected": {
    "status": 200,
    "body": {
      "hookSpecificOutput": {
        "hookEventName": "PreToolUse",
        "permissionDecision": "allow",
        "additionalContext": "<ignored>"
      },
      "status": "stale",
      "summary": {
        "path": "CLAUDE.md",
        "current_version": 2,
        "prior_version_seen_by_session": 1,
        "last_writer_session_id": "a0826622451ec196f",
        "last_writer_at_unix_ts": 0,
        "warning_generated_at_unix_ts": 0,
        "hash_differs": false
      }
    }
  },
  "ignore_keys": ["additionalContext", "last_writer_at_unix_ts", "warning_generated_at_unix_ts"]
}
